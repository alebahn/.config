#!/usr/bin/bash

cmd="$1"; shift

# set -x

#if no command is given, print usage and exit
if [ -z "$cmd" ]; then
  echo "Usage: git-indexed.sh <command> [<args>]"
  echo "Example: git-indexed.sh add 1 2 3"
  echo "This will run 'git add' on the files indexed by numbers 1, 2, and 3."
  exit 1
fi

root_path="$(git rev-parse --show-toplevel)"

args=()
for arg in "$@"; do
  #if arg is numeric, convert it to a file:
  if [[ "$arg" =~ ^[0-9]+$ ]]; then
    if ! file=$(
      git status --porcelain -z | \
        awk -v RS='\0' -v arg="$arg" '
          {
            if (skip_next_path) {
              skip_next_path = 0
              next
            }

            status = substr($0, 1, 2)
            path = substr($0, 4)
            x = substr(status, 1, 1)
            y = substr(status, 2, 1)

            if (x ~ /^[RC]$/) {
              skip_next_path = 1
            }

            if (status == "??") {
              untracked[++nt] = path
              next
            }

            if (status ~ /^(DD|AU|UD|UA|DU|AA|UU)$/) {
              unmerged[++nm] = path
              next
            }

            if (x ~ /^[MTADRC]$/) {
              staged[++ns] = path
            }
            if (y ~ /^[MTD]$/) {
              unstaged[++nu] = path
            }
          }
          END {
            count = 0
            for (i = 1; i <= ns; i++) { if (++count == arg) { print staged[i]; exit } }
            for (i = 1; i <= nm; i++) { if (++count == arg) { print unmerged[i]; exit } }
            for (i = 1; i <= nu; i++) { if (++count == arg) { print unstaged[i]; exit } }
            for (i = 1; i <= nt; i++) { if (++count == arg) { print untracked[i]; exit } }
            exit 1
          }'
        ); then
      echo "git-indexed: no file for index $arg" >&2
      exit 1
    fi

    args+=("$root_path/$file")
  #otherwise, pass it through as is
  else
    args+=("$arg")
  fi
done

# echo "$cmd" "${args[@]}"
git "$cmd" "${args[@]}"
