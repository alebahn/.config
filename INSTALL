#!/bin/sh

overwrite_bashrc=0

while [ "$#" -gt 0 ]; do
    case "$1" in
        --overwrite-bashrc)
            overwrite_bashrc=1
            ;;
        -h|--help)
            echo "Usage: ./INSTALL [--overwrite-bashrc]"
            echo
            echo "  --overwrite-bashrc  Replace an existing non-symlink ~/.bashrc"
            echo "                      instead of moving it into bash/dot-bashrc."
            exit 0
            ;;
        *)
            echo "Unknown option: $1" >&2
            echo "Usage: ./INSTALL [--overwrite-bashrc]" >&2
            exit 1
            ;;
    esac
    shift
done

cd ~/.config/

git submodule init
git submodule update
if [ ! -L nvim/lua/custom ]; then
    ln -s ../../nvim_custom nvim/lua/custom
fi

if [ -e "$HOME/.bashrc" ] && [ ! -L "$HOME/.bashrc" ]; then
    if [ "$overwrite_bashrc" -eq 1 ]; then
        rm -f "$HOME/.bashrc"
    else
        mv "$HOME/.bashrc" "$HOME/.config/bash/dot-bashrc"
    fi
fi

ln -sfn "$HOME/.config/bash/dot-bashrc" "$HOME/.bashrc"

# Check current global git user name
current_name=$(git config --global user.name)
if [ -n "$current_name" ]; then
  echo "Git user.name is already set to: $current_name"
else
  read -p "Enter your Git name: " git_name
  git config -f ../.gitconfig user.name "$git_name"
fi

# Check current global git user email
current_email=$(git config --global user.email)
if [ -n "$current_email" ]; then
  echo "Git user.email is already set to: $current_email"
else
  read -p "Enter your Git email: " git_email
  git config -f ../.gitconfig user.email "$git_email"
fi

# Confirm current values
echo "Final Git global config:"
git config --global --get user.name
git config --global --get user.email
